{
  "expo": {
    "name": "CobroYa",
    "slug": "cobroya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "cobroya",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.cobroya.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Usa Face ID para proteger tu cuenta de Mercado Pago"
      }
    },
    "android": {
      "package": "app.cobroya.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["VIBRATE"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00D68F"
        }
      ],
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "cobroya-app"
      }
    }
  }
}
